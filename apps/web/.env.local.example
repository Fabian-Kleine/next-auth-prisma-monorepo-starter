# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"

# Database (must match packages/db/.env)
DATABASE_URL="postgres://postgres_app:postgres@127.0.0.1:5432/next_auth_starter_dev?sslmode=disable"
USE_ACCELERATE=false

# Resend — leave RESEND_API_KEY blank to log emails to the console in dev.
RESEND_API_KEY=""
EMAIL_FROM="Next Auth Starter <onboarding@resend.dev>"
