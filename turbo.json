{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["NODE_ENV"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "NEXT_PUBLIC_APP_URL",
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "PRISMA_ACCELERATE_URL",
        "USE_ACCELERATE",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "RESEND_API_KEY",
        "EMAIL_FROM"
      ]
    },
    "lint": { "dependsOn": ["^lint"] },
    "check-types": { "dependsOn": ["^check-types"] },
    "dev": { "cache": false, "persistent": true }
  }
}
