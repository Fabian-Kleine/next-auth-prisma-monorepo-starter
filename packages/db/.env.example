# Prisma connection strings.
# Defaults below match docker-compose.yml in this package (run `pnpm docker:up`).
DATABASE_URL="postgres://postgres_app:postgres@127.0.0.1:5432/next_auth_starter_dev?sslmode=disable"

# Optional direct (non-pooled) connection used by seed/migration scripts.
# Falls back to DATABASE_URL when unset.
DIRECT_DATABASE_URL="postgres://postgres_app:postgres@127.0.0.1:5432/next_auth_starter_dev?sslmode=disable"

# Shadow database used by `prisma migrate dev`.
SHADOW_DATABASE_URL="postgres://postgres_app:postgres@127.0.0.1:5432/next_auth_starter_dev_shadow?sslmode=disable"

# Optional Prisma Accelerate URL. Leave USE_ACCELERATE=false for local Postgres.
PRISMA_ACCELERATE_URL=""
USE_ACCELERATE=false
