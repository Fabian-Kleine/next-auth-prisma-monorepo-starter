{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "es2017",
    "plugins": [{ "name": "next" }],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "auto",
    "isolatedModules": true,
    "allowJs": true,
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "declaration": false,
    "declarationMap": false
  }
}
